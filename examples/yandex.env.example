# Canonical env template is mirrored from:
#   plugins/yandex-direct-for-all/examples/yandex.env.example
#
# Runtime tokens for API work
YD_TOKEN=
YD_CLIENT_LOGIN=
YD_SANDBOX=false
YD_OUTPUT_DIR=

# Default launcher path no longer requires filling client_id/client_secret by hand.
# Built-in public profiles + PKCE are used automatically from:
#   config/yandex_oauth_public_profiles.json
#
# Variables below are only optional overrides if you want:
# - your own OAuth app instead of the built-in public profile
# - a legacy/device flow with explicit client_secret
# - custom auth output paths
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_SCOPE=
YANDEX_OAUTH_REDIRECT_URI=
YANDEX_OAUTH_TOKEN_PATH=
YANDEX_OAUTH_ENV_PATH=
YANDEX_AUTH_OUTPUT_DIR=
YANDEX_OAUTH_AUTH_ROOT=

# Optional service-specific overrides
YANDEX_DIRECT_OAUTH_CLIENT_ID=
YANDEX_DIRECT_OAUTH_CLIENT_SECRET=
YANDEX_DIRECT_OAUTH_SCOPE=
YANDEX_DIRECT_OAUTH_REDIRECT_URI=
YANDEX_DIRECT_OAUTH_TOKEN_PATH=
YANDEX_DIRECT_OAUTH_ENV_PATH=

YANDEX_METRIKA_OAUTH_CLIENT_ID=
YANDEX_METRIKA_OAUTH_CLIENT_SECRET=
YANDEX_METRIKA_OAUTH_SCOPE=
YANDEX_METRIKA_OAUTH_REDIRECT_URI=
YANDEX_METRIKA_OAUTH_TOKEN_PATH=
YANDEX_METRIKA_OAUTH_ENV_PATH=

YANDEX_AUDIENCE_OAUTH_CLIENT_ID=
YANDEX_AUDIENCE_OAUTH_CLIENT_SECRET=
YANDEX_AUDIENCE_OAUTH_SCOPE=
YANDEX_AUDIENCE_OAUTH_REDIRECT_URI=
YANDEX_AUDIENCE_OAUTH_TOKEN_PATH=
YANDEX_AUDIENCE_OAUTH_ENV_PATH=

# Generated by scripts/start_yandex_user_auth.sh or exchange_yandex_user_code.sh
# Default location: ./.codex/auth/
# direct_oauth.env          -> export YD_TOKEN=...
# metrika_oauth.env         -> export YANDEX_METRIKA_TOKEN=...
# audience_oauth.env        -> export YANDEX_AUDIENCE_TOKEN=...
# direct_oauth_preflight.json / metrika_oauth_preflight.json / audience_oauth_preflight.json

# Wordstat and Search API are a separate cloud auth model.
YANDEX_WORDSTAT_TOKEN=
YANDEX_WORDSTAT_CLIENT_PATH=

SEARCH_API_KEY=
FOLDER_ID=
YANDEX_SEARCH_API_KEY=
YANDEX_SEARCH_FOLDER_ID=

# Optional runtime tokens
YANDEX_METRIKA_TOKEN=
YANDEX_METRIKA_COUNTER_ID=
YANDEX_AUDIENCE_TOKEN=
